# URL del backend identity-service
VITE_API_URL=http://localhost:3001

# URL del microservicio financial-service
VITE_FINANCIAL_API_URL=http://localhost:3004

# URL del notifications-service (REST de la bandeja + WebSocket en tiempo real)
VITE_NOTIFICATIONS_API_URL=http://localhost:3006

# URL del products-service (catálogo: menú por tienda y carrito)
VITE_PRODUCTS_SERVICE_URL=http://localhost:3000

# URL del orders-service (pedidos, carrito DRAFT, chat)
VITE_ORDERS_SERVICE_URL=http://localhost:3000

# Azure Blob Storage: URL PÚBLICA (solo lectura) del contenedor con los logos de las tiendas.
# Los archivos se llaman <storeId>.png. NUNCA pongas aquí la cadena de conexión / AccountKey.
VITE_STORE_LOGOS_URL=https://eciexpressprodst.blob.core.windows.net/store-logos

# Wompi sandbox: llave PUBLICA (pub_test_...) para tokenizar tarjetas desde el navegador.
VITE_WOMPI_PUBLIC_KEY=
VITE_WOMPI_BASE_URL=https://sandbox.wompi.co/v1

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
